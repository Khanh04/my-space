      <section class="projects-section" data-filterable>
        <p class="eyebrow">03 · Selected projects</p>
        <h2>Things I&rsquo;ve built.</h2>
        <div class="projects">
          {projects.map((p) => (
            <article class="project" data-tags={p.tags.join(' ')}>
              <h3>{p.title}</h3>
              <p>{p.body}</p>
