          Open to conversations about production ML, inference infrastructure, and LLM tooling. The fastest way to reach me is email.
        </p>
        <div class="contact-links">
          <a href="mailto:khanhng93@proton.me">
            <span class="label">Email</span>khanhng93@proton.me
          </a>
          <a href="https://linkedin.com/in/khanh-nguyen-0" target="_blank" rel="noopener">
            <span class="label">LinkedIn</span>linkedin.com/in/khanh-nguyen-0
          </a>
          <a href="https://github.com/" target="_blank" rel="noopener">
            <span class="label">GitHub</span>github.com
          </a>
        </div>
      </section>

      <footer>
        <span>© 2026 Khanh Nguyen</span>
        <span>Helsinki · Finland</span>
      </footer>
    </main>

    <script is:inline>
      (() => {
        const themeBtns = document.querySelectorAll('[data-theme-set]');
        const media = window.matchMedia('(prefers-color-scheme: dark)');
        const paintTheme = () => {
          const stored = localStorage.getItem('theme');
          const effective = stored || (media.matches ? 'dark' : 'light');
          themeBtns.forEach((b) => b.classList.toggle('is-active', b.dataset.themeSet === effective));
        };
        themeBtns.forEach((b) => {
          b.addEventListener('click', () => {
            const t = b.dataset.themeSet;
            document.documentElement.setAttribute('data-theme', t);
            localStorage.setItem('theme', t);
            paintTheme();
          });
        });
        media.addEventListener('change', paintTheme);
        paintTheme();
      })();

      (() => {
        const tags = document.querySelectorAll('.tag');
        const items = document.querySelectorAll('[data-tags]');
        const sections = document.querySelectorAll('[data-filterable]');
        const clear = document.querySelector('[data-clear]');
        const HIDE_MS = 320;
        const APPEAR_MS = 420;
        const active = new Set();

        const setState = (el, shouldShow) => {
          clearTimeout(el._timer);
          const wasGone = el.classList.contains('is-gone');
          if (shouldShow) {
            el.classList.remove('is-collapsing', 'is-gone');
            if (wasGone) {
              el.classList.add('is-appearing');
              el._timer = setTimeout(() => el.classList.remove('is-appearing'), APPEAR_MS);
            }
          } else if (!wasGone) {
            el.classList.remove('is-appearing');
            el.classList.add('is-collapsing');
            el._timer = setTimeout(() => el.classList.add('is-gone'), HIDE_MS);
          }
        };

        const matches = (el) =>
          (el.dataset.tags || '').split(' ').some((t) => active.has(t));

        const render = () => {
          const hasFilter = active.size > 0;
          if (hasFilter) document.body.setAttribute('data-filter', 'on');
          else document.body.removeAttribute('data-filter');

          tags.forEach((t) => t.classList.toggle('is-active', active.has(t.dataset.tag)));

          items.forEach((el) => setState(el, !hasFilter || matches(el)));

          sections.forEach((section) => {
            if (!hasFilter) return setState(section, true);
            const anyMatch = Array.from(section.querySelectorAll('[data-tags]')).some(matches);
            setState(section, anyMatch);
          });

          clear.hidden = !hasFilter;
        };

        tags.forEach((t) => {
          t.addEventListener('click', () => {
            const key = t.dataset.tag;
            if (active.has(key)) active.delete(key);
            else active.add(key);
            render();
          });
        });

        clear.addEventListener('click', () => {
          active.clear();
          render();
        });
      })();
    </script>
  </body>
</html>
