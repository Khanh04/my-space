---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Khanh Nguyen — ML Engineer</title>
    <meta name="description" content="Machine Learning engineer building production inference systems — speech, NLP, and LLM agents. Based in Helsinki." />
    <meta property="og:title" content="Khanh Nguyen — ML Engineer" />
    <meta property="og:description" content="Machine Learning engineer building production inference systems — speech, NLP, and LLM agents." />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <script is:inline>
      (() => {
        const t = localStorage.getItem('theme');
        if (t === 'light' || t === 'dark') document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
  </head>
  <body>
    <div class="theme-toggle" role="group" aria-label="Theme">
      <button type="button" data-theme-set="light" aria-label="Light theme">light</button>
      <span class="sep" aria-hidden="true">·</span>
      <button type="button" data-theme-set="dark" aria-label="Dark theme">dark</button>
    </div>
    <main>
      <section class="hero">
        <h1>Khanh Nguyen</h1>
        <p class="lede">
          Senior software engineer, specialize in building production ML systems from Helsinki.
        </p>
        <div class="meta">
          <span>Helsinki, FI</span>
          <span class="sep">·</span>
          <a href="mailto:khanhng93@proton.me">khanhng93@proton.me</a>
          <span class="sep">·</span>
          <a href="https://linkedin.com/in/khanh-nguyen-0" target="_blank" rel="noopener">LinkedIn</a>
          <span class="sep">·</span>
          <a href="https://github.com/" target="_blank" rel="noopener">GitHub</a>
        </div>
      </section>

      <section class="about">
        <p class="eyebrow">01 · About</p>
        <h2>Some context.</h2>
        <p>
          I'm a software engineer based in Helsinki with eight years of experience building production systems, from machine learning to backend infrastructure. 
          I'm interested in building scalable ML systems for real world applications and exploring new technologies.
        </p>
        <p>
          Beyond ML, I'm interested in systems design and developer experience.
        </p>
      </section>

      <section class="filter" aria-label="Filter by skill">
        <div class="filter-groups">
          {skillGroups.map((g) => (
            <div class="filter-group">
              <span class="filter-group-label">{g.label}</span>
              <div class="filter-group-tags">
                {g.tags.map((t, i) => (
                  <span class="tag-item">
                    <button type="button" class="tag" data-tag={t.key}>{t.label}</button>
                    {i < g.tags.length - 1 && <span class="sep" aria-hidden="true">·</span>}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
        <button type="button" class="tag-clear" data-clear hidden>clear filters</button>
      </section>

      <section class="experience" data-filterable>
        <p class="eyebrow">02 · Experience</p>
        <h2>Selected roles.</h2>
        <div class="roles">
          {experience.map((r) => (
            <article class="role" data-tags={[...new Set(r.bullets.flatMap((b) => b.tags))].join(' ')}>
              <div class="role-head">
                <div class="role-title">
                  <span>{r.role}</span>
                  <span class="company">{r.company}</span>
                </div>
                <div class="role-period">{r.period}</div>
              </div>
              <div class="role-location">{r.location}</div>
              <ul>
                {r.bullets.map((b) => <li data-tags={b.tags.join(' ')}>{b.text}</li>)}
